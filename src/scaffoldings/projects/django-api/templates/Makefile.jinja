{% if package_manager == "uv" -%}
INSTALL := uv sync
RUN := uv run
ADD := uv add
REMOVE := uv remove
{% elif package_manager == "poetry" -%}
INSTALL := poetry install
RUN := poetry run
ADD := poetry add
REMOVE := poetry remove
{% else -%}
INSTALL := pdm install
RUN := pdm run
ADD := pdm add
REMOVE := pdm remove
{% endif -%}
OA_URL ?= http://127.0.0.1:8000/api/openapi.json
PORT ?= 8000

.PHONY: init dev m mm mz oa add remove

init:
	mkdir -p .dev shared
	$(INSTALL)

dev:
	$(RUN) python manage.py runserver $(PORT)

m:
	$(RUN) python manage.py migrate

mm:
	@test -n "$(app)" || (echo "usage: make mm app=<app>" && exit 2)
	$(RUN) python manage.py makemigrations $(app)

mz:
	@test -n "$(app)" || (echo "usage: make mz app=<app>" && exit 2)
	$(RUN) python manage.py migrate $(app) zero
	find $(app)/migrations -type f ! -name __init__.py -delete
	find $(app)/migrations -type d -name __pycache__ -prune -exec rm -rf {} +

oa:
	mkdir -p shared
	rm -rf shared/oa
	$(RUN) openapi-python-client generate --url $(OA_URL) --config openapi-python-client.yml --output-path shared/oa --overwrite --meta none

add:
	@test -n "$(pkg)" || (echo "usage: make add pkg=<pkg>" && exit 2)
	$(ADD) $(pkg)

remove:
	@test -n "$(pkg)" || (echo "usage: make remove pkg=<pkg>" && exit 2)
	$(REMOVE) $(pkg)

modwire:
	modwire -d .modwire architecture health . python