from importlib import import_module
from inspect import isclass
from pkgutil import walk_packages

from django.apps import apps
from ninja_extra import NinjaExtraAPI

api = NinjaExtraAPI(title="{{ project_title }} API", version="0.1.0")


def _mods(pkg):
    yield pkg
    if hasattr(pkg, "__path__"):
        yield from (import_module(m.name) for m in walk_packages(pkg.__path__, pkg.__name__ + "."))


def _controllers():
    for app in apps.get_app_configs():
        try:
            pkg = import_module(f"{app.name}.api")
        except ModuleNotFoundError as e:
            if e.name != f"{app.name}.api":
                raise
            continue
        for mod in _mods(pkg):
            yield from (
                v for v in vars(mod).values()
                if isclass(v) and v.__module__ == mod.__name__ and v.__name__.endswith("Controller")
            )


for c in _controllers():
    api.register_controllers(c)
