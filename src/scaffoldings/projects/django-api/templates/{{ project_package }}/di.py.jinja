from importlib import import_module
from pkgutil import walk_packages

import wireup
from django.apps import apps

_container = None


def _import(name, root):
    try:
        return import_module(name)
    except ModuleNotFoundError as e:
        if e.name == name or e.name.startswith(root + "."):
            return None
        raise


def _service_modules():
    for app in apps.get_app_configs():
        pkg = _import(f"{app.name}.services", app.name)
        if not pkg:
            continue
        yield pkg
        if hasattr(pkg, "__path__"):
            for m in walk_packages(pkg.__path__, pkg.__name__ + "."):
                if mod := _import(m.name, app.name):
                    yield mod


def container():
    global _container
    if _container is None:
        _container = wireup.create_sync_container(injectables=list(_service_modules()))
    return _container


def get(service):
    return container().get(service)
