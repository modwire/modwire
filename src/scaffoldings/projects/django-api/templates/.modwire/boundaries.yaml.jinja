tags:
  - name: app
    match: "*"
    excluded_patterns:
      - "{{ project_package }}"
      - ".dev"
      - "manage"

  - name: project
    match: "{{ project_package }}"

  - name: entrypoint
    match: "manage"

  - name: project_api
    match: "{{ project_package }}/api"

  - name: routing
    match: "{{ project_package }}/urls"

  - name: runtime
    match: "{{ project_package }}/asgi"

  - name: runtime
    match: "{{ project_package }}/wsgi"

  - name: settings
    match: "{{ project_package }}/settings"

  - name: app_config
    match: "*/apps"

  - name: api
    match: "*/api"

  - name: admin
    match: "*/admin"

  - name: management
    match: "*/management"

  - name: services
    match: "*/services"

  - name: models
    match: "*/models"

  - name: migrations
    match: "*/migrations"

rules: []

flow:
  module_tag: app
  layers:
    - app_config
    - api
    - admin
    - management
    - services
    - models
    - migrations
  realms:
    - name: project
      module_tag: project
      layers:
        - entrypoint
        - routing
        - runtime
        - project_api
        - settings
  analyzers:
    - backward-flow
    - no-cycles
    - no-reentry
