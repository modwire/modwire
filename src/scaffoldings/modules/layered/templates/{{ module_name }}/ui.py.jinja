import typer

from . import application

app = typer.Typer(help="Run {{ module_name }} commands.")


def render(name: str) -> str:
    item = application.bootstrap().handle(name)
    return item.name


@app.command("render")
def render_command(name: str) -> None:
    typer.echo(render(name))


__all__ = ["app", "render"]
