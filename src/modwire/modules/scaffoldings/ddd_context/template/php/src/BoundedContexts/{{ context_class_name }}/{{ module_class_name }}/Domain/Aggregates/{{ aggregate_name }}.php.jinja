<?php

declare(strict_types=1);

namespace {{ php_namespace }}\Domain\Aggregates;

use {{ php_namespace }}\Domain\Entities\{{ entity_name }};
use {{ php_namespace }}\Domain\Events\{{ event_name }};
use {{ php_namespace }}\Domain\ValueObjects\{{ value_object_name }};

final class {{ aggregate_name }}
{
    /** @var list<{{ event_name }}> */
    private array $events = [];

    private function __construct(
        public readonly string $aggregateId,
        public readonly {{ entity_name }} $entity,
    ) {
    }

    public static function create(string $aggregateId, string $name): self
    {
        $entity = new {{ entity_name }}($aggregateId, new {{ value_object_name }}($name));
        $aggregate = new self($aggregateId, $entity);
        $aggregate->events[] = new {{ event_name }}($aggregateId, $name);

        return $aggregate;
    }

    public function name(): string
    {
        return $this->entity->name->value;
    }

    /** @return list<{{ event_name }}> */
    public function pullEvents(): array
    {
        $events = $this->events;
        $this->events = [];

        return $events;
    }
}
