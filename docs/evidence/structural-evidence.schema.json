{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/modwire/modwire-ecosystem/blob/main/governance/structural-evidence.schema.json",
  "title": "Modwire structural change evidence bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "operation", "subject", "evidence"],
  "properties": {
    "$schema": {"const": "./structural-evidence.schema.json"},
    "schema_version": {"const": 1},
    "operation": {
      "enum": ["repository_rename", "package_identity_change", "breaking_release", "repository_retirement"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id"],
      "properties": {"repository_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
    },
    "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/item"}}
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference", "summary"],
      "properties": {
        "kind": {
          "enum": ["identity_mapping", "github_redirect", "migration_guide", "artifact_install", "compatibility", "documentation", "archive_authorization", "rollback_plan", "owner_approval"]
        },
        "reference": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1}
      }
    }
  }
}
